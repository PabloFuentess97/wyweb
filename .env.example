# ──────────────────────────────────────────────────────────────────────────
# Wyweb — variables de entorno
#
# Copia este archivo a `.env` y rellena los valores. Las variables marcadas
# como (REQ) son obligatorias para que la app arranque; el resto tienen
# defaults sensatos en src/lib/env.ts.
# ──────────────────────────────────────────────────────────────────────────

# ─── Core
NODE_ENV=development

# ─── Base de datos (REQ)
# Local con docker-compose:
DATABASE_URL=postgres://wyweb:uxea_dev_pwd@localhost:5432/wyweb
# Remoto (forzará SSL automáticamente):
# DATABASE_URL=postgres://user:pwd@host.example.com:5432/db

# ─── Auth.js (REQ)
# Genera con: openssl rand -base64 48
AUTH_SECRET=change-me-to-a-secret-of-at-least-32-chars
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ─── Email transaccional (Resend)
# Crea API key en https://resend.com — opcional en dev (falla silencioso)
RESEND_API_KEY=
EMAIL_FROM=Wyweb <noreply@wyweb.net>
EMAIL_TO_LEADS=info@wyweb.net

# ─── Storage (MinIO local con docker-compose, S3 en VPS)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=wyweb-net
S3_PUBLIC_URL=http://localhost:9000

# ─── Redis (rate-limit, sesiones, cron) — opcional
REDIS_URL=redis://localhost:6379

# ─── Cifrado en reposo (campos sensibles), 32+ chars
APP_ENCRYPTION_KEY=

# ─── Cron secret (para /api/cron/sla-check)
CRON_SECRET=change-me-to-a-random-string

# ─── Sentry / Glitchtip — opcional
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Plausible — opcional
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ─── Billing
# Opciones: noop | self-built | holded | quaderno
BILLING_PROVIDER=self-built

# ─── GitHub (para enlaces "Editar en GitHub" desde /admin/contenido)
GITHUB_REPO_URL=https://github.com/PabloFuentess97/wyweb
GITHUB_DEFAULT_BRANCH=main

# ─── Public
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRAND=wyweb
